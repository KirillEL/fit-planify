# PostgreSQL
POSTGRES_DB=planify
POSTGRES_USER=planify
POSTGRES_PASSWORD=your_db_password

# API
DATABASE_URL=postgres://planify:your_db_password@postgres:5432/planify?sslmode=disable
JWT_SECRET=your_jwt_secret_min_32_chars
API_PORT=8080
DEV_MODE=false

# Bot
BOT_TOKEN=123456:your_bot_token_from_botfather
BOT_SECRET=your_bot_secret_for_notify_endpoint
API_URL=http://api:8080
MINI_APP_URL=https://your-domain.com
TZ=Asia/Novosibirsk

# Frontend (injected at build time)
VITE_API_URL=https://your-domain.com
